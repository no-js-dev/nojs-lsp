          "description": "No.JS: Template ID shown on success"
        },
        {
          "name": "then",
          "type": "expression",
          "description": "No.JS: Expression executed on success"
        },
        {
          "name": "redirect",
          "type": "string",
          "description": "No.JS: Path to redirect after success"
        },
        {
          "name": "confirm",
          "type": "string",
          "description": "No.JS: Confirmation message before request"
        },
        {
